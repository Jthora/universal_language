{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/Jthora/universal_language/blob/main/ul-forge/schemas/ul-transceiver.schema.json",
  "title": "UL Transceiver Protocol",
  "description": "Message envelope schema for UL Transceiver — agent-to-agent communication over Geometric Intermediate Representation (GIR).",
  "type": "object",
  "required": ["version", "message"],
  "properties": {
    "version": {
      "type": "string",
      "const": "0.1.0",
      "description": "Protocol version"
    },
    "message": {
      "$ref": "#/$defs/ULMessage"
    }
  },
  "$defs": {
    "ULMessage": {
      "type": "object",
      "required": ["id", "timestamp", "sender", "intent", "payload"],
      "properties": {
        "id": {
          "type": "string",
          "format": "uuid",
          "description": "Unique message identifier"
        },
        "timestamp": {
          "type": "string",
          "format": "date-time",
          "description": "ISO 8601 timestamp"
        },
        "sender": {
          "$ref": "#/$defs/AgentIdentity"
        },
        "intent": {
          "$ref": "#/$defs/Intent"
        },
        "payload": {
          "$ref": "#/$defs/Payload"
        },
        "context": {
          "$ref": "#/$defs/MessageContext"
        }
      }
    },
    "AgentIdentity": {
      "type": "object",
      "required": ["id", "capabilities"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique agent identifier"
        },
        "capabilities": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/Capability"
          },
          "description": "Operations this agent can perform"
        }
      }
    },
    "Capability": {
      "type": "string",
      "enum": ["parse", "validate", "render", "evaluate", "compose", "deparse", "analyze"]
    },
    "Intent": {
      "type": "string",
      "enum": [
        "assert",
        "query",
        "propose",
        "refine",
        "validate_request",
        "validate_response",
        "capability_advertisement",
        "ack"
      ],
      "description": "The communicative intent of this message"
    },
    "Payload": {
      "type": "object",
      "required": ["format", "content"],
      "properties": {
        "format": {
          "$ref": "#/$defs/PayloadFormat"
        },
        "content": {
          "description": "Payload content — structure depends on format field",
          "oneOf": [
            { "$ref": "#/$defs/Gir" },
            { "type": "string" },
            { "$ref": "#/$defs/ValidationResult" },
            { "$ref": "#/$defs/CapabilityAdvertisement" },
            { "type": "object", "properties": { "uri": { "type": "string", "format": "uri" } } }
          ]
        },
        "confidence": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Sender's confidence in this payload (optional)"
        }
      }
    },
    "PayloadFormat": {
      "type": "string",
      "enum": ["gir", "ul_script", "validation_result", "capability_list", "reference"]
    },
    "MessageContext": {
      "type": "object",
      "properties": {
        "conversation_id": {
          "type": "string",
          "format": "uuid",
          "description": "Groups related messages into a conversation"
        },
        "in_reply_to": {
          "type": "string",
          "format": "uuid",
          "description": "ID of the message this replies to"
        },
        "domain": {
          "type": "string",
          "description": "Knowledge domain hint (e.g., 'physics', 'linguistics')"
        },
        "sequence": {
          "type": "integer",
          "minimum": 0,
          "description": "Monotonically increasing sequence number within conversation"
        }
      }
    },
    "CapabilityAdvertisement": {
      "type": "object",
      "properties": {
        "operations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/OperationDescriptor"
          }
        },
        "supported_sorts": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["entity", "relation", "modifier", "assertion"]
          }
        },
        "max_gir_nodes": {
          "type": "integer",
          "minimum": 1,
          "description": "Maximum GIR nodes this agent can process"
        }
      }
    },
    "OperationDescriptor": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": {
          "type": "string",
          "description": "Operation name (one of the 13 Σ_UL operations or extensions)"
        },
        "input": {
          "type": "string",
          "description": "Input sort signature (e.g., 'e × r × e')"
        },
        "output": {
          "type": "string",
          "description": "Output sort (e.g., 'a')"
        }
      }
    },
    "Gir": {
      "type": "object",
      "description": "Geometric Intermediate Representation",
      "properties": {
        "nodes": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "node_type", "sort"],
            "properties": {
              "id": { "type": "string" },
              "node_type": {
                "type": "string",
                "enum": ["point", "line", "angle", "curve", "enclosure"]
              },
              "sort": {
                "type": "string",
                "enum": ["entity", "relation", "modifier", "assertion"]
              },
              "label": { "type": "string" }
            }
          }
        },
        "edges": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["source", "target", "edge_type"],
            "properties": {
              "source": { "type": "string" },
              "target": { "type": "string" },
              "edge_type": {
                "type": "string",
                "enum": ["contains", "modified_by", "adjacent", "intersects", "connects", "references", "binds", "accessible_from"]
              }
            }
          }
        }
      }
    },
    "ValidationResult": {
      "type": "object",
      "properties": {
        "valid": { "type": "boolean" },
        "errors": {
          "type": "array",
          "items": { "type": "string" }
        },
        "warnings": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
